{
  "name": "gtowerdefense",
  "version": "1.0.0",
  "description": "Guardians of the Realm — Enterprise-Grade Tower Defense Game Engine",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,json,css,html}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isianust/GTowerDefense.git"
  },
  "keywords": ["tower-defense", "html5-game", "canvas", "typescript", "game-engine"],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/isianust/GTowerDefense/issues"
  },
  "homepage": "https://github.com/isianust/GTowerDefense#readme",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
